# .env.example — safe to commit to GitHub (contains NO real secrets)
# ---------------------------------------------------------------
# To use: cp .env.example .env   then fill in your real values.
# The .env file is listed in .gitignore and will never be committed.

# === Ollama (primary AI — runs locally, no API costs) ===
# Point this at whichever machine is running Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5

# === Anthropic API (fallback — used only when Ollama is unavailable) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Claude fallback models (used if Ollama fails) ===
EVALUATOR_MODEL=claude-opus-4-6
COVER_LETTER_MODEL=claude-opus-4-6

# === LinkedIn ===
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your_password_here

# === ZipRecruiter ===
ZIPRECRUITER_EMAIL=you@example.com
ZIPRECRUITER_PASSWORD=your_password_here

# === Application behavior ===
# Minimum fit score (0–100) required to auto-apply
MIN_FIT_SCORE=70

# Hard cap on successful applications per day
MAX_APPLICATIONS_PER_DAY=10

# Set to True to evaluate only; False to actually submit applications
DRY_RUN=True

# === Scraper tuning ===
# Max LinkedIn job cards per browser session (keep low to avoid detection)
LINKEDIN_MAX_JOBS_PER_SESSION=40

# Random delay range between page loads (seconds)
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=7.0
